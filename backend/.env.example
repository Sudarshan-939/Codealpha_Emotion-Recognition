# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# NVIDIA NIM API Key (get from https://build.nvidia.com/)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Server configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

# Audio processing
SAMPLE_RATE=16000
MAX_AUDIO_DURATION=10
N_MFCC=40
N_MELS=128
HOP_LENGTH=512

# Training
RANDOM_SEED=42
TEST_SIZE=0.2
VALIDATION_SIZE=0.15
BATCH_SIZE=32
EPOCHS=100
LEARNING_RATE=0.001
